generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Process vs Anchor philosophy: Anchors are fixed time constraints, Processes are goals with logs

model Anchor {
  id        String   @id @default(uuid())
  title     String   // e.g., "Work"
  startTime String   // e.g., "09:00"
  endTime   String   // e.g., "17:00"
  day       String   @default("Daily") // e.g., "Daily", "Monday", "Weekday"
  createdAt DateTime @default(now())
}

model Process {
  id        String   @id @default(uuid())
  title     String   @unique // e.g., "Diet", "Chess"
  goal      String?  // e.g., "Hit 70kg"
  type      String   @default("PROCESS")
  day       String?   // Used when type is ANCHOR
  startTime String?   // Used when type is ANCHOR
  endTime   String?   // Used when type is ANCHOR
  createdAt DateTime @default(now())

  logs      Log[]
}

model Log {
  id        String   @id @default(uuid())
  content   String   // e.g., "Ate an apple"
  createdAt DateTime @default(now())

  processId  String
  process   Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
}

// Chat history remains as a single global stream
model Message {
  id        String   @id @default(uuid())
  role      String   // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())
}

model DailySchedule {
  id        String   @id @default(cuid())
  date      String   @unique
  content   String
  updatedAt DateTime @updatedAt
}
