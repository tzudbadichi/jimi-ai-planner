generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Track {
  id        String    @id @default(uuid())
  name      String
  type      String    // "ANCHOR" or "GROWTH"
  goals     String    // JSON string of goals
  createdAt DateTime  @default(now())
  
  // קשר להודעות: לכל מסלול יכולות להיות הרבה הודעות
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  role      String   // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())

  // שיוך אופציונלי למסלול
  // אם trackId ריק -> זה שייך לצ'אט הראשי (Main Chat)
  // אם trackId מלא -> זה שייך למסלול הספציפי
  trackId   String?
  track     Track?   @relation(fields: [trackId], references: [id], onDelete: Cascade)
}